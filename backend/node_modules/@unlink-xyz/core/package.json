{
  "name": "@unlink-xyz/core",
  "version": "0.1.7-canary.7512856",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/browser/index.js",
        "types": "./dist/index.d.ts"
      },
      "default": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "./wallet": {
      "browser": {
        "import": "./dist/browser/wallet/index.js",
        "types": "./dist/wallet/index.d.ts"
      },
      "default": {
        "import": "./dist/wallet/index.js",
        "types": "./dist/wallet/index.d.ts"
      }
    },
    "./utils/async.js": {
      "import": "./dist/utils/async.js",
      "types": "./dist/utils/async.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && tsup && tsup --config tsup.browser.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "tsc --noEmit && vitest run --test-timeout 0",
    "setup:artifacts": "bash ./scripts/setup-artifacts.sh",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "2.0.0",
    "@scure/base": "2.0.0",
    "@scure/bip39": "2.0.1",
    "@types/snarkjs": "^0.7.9",
    "@zk-kit/eddsa-poseidon": "^1.1.0",
    "@zk-kit/imt": "2.0.0-beta.8",
    "buffer": "^6.0.3",
    "ethereum-cryptography": "3.2.0",
    "ethers": "6.15.0",
    "ky": "^1.14.0",
    "snarkjs": "^0.7.5",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.19.0",
    "fake-indexeddb": "6.2.4",
    "poseidon-lite": "^0.3.0",
    "prettier": "^3.5.3",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vitest": "4.0.1"
  }
}
